rules_version = '2';

// Reguły Firestore dla Spokojny Rodzic
//
// Dodano kolekcję users/{uid}/tokens/{token} dla FCM:
// - User może czytać/pisać tylko swoje tokeny
// - Cloud Functions (admin SDK) bypasses te reguły, więc Cloud Function
//   może czytać tokeny wszystkich userów do wysyłania push
//
// Reszta reguł — istniejące dla profili, leków, etc.

service cloud.firestore {
  match /databases/{database}/documents {

    // FCM tokens — user może zarządzać tylko swoimi
    match /users/{userId}/tokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Profile dziecka — user czyta/pisze tylko swoje
    match /users/{userId}/profiles/{profileId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sub-kolekcje (meds, feeds, sleeps, temps, itd.)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Domyślnie blokuj wszystko inne
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
