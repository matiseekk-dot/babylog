rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
// BABYLOG / CALM PARENT — FIRESTORE RULES
//
// Zasady:
//   1. Każdy user ma dostęp TYLKO do /users/{userId}/**
//   2. userId MUSI odpowiadać request.auth.uid — nie można czytać cudzych danych
//   3. Niezalogowani (brak auth) — zero dostępu
//   4. Wszystko poza /users/ — zablokowane
//
// Audyt 2026-04-21:
//   - Sprawdzone: user A nie widzi /users/UID_B (permission denied)
//   - Sprawdzone: guest (brak uid) — zero dostępu
//   - Sprawdzone: brak ścieżek collateral typu /public/* które byłyby otwarte
// ══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // === Dane użytkownika ===================================================
    // Dostęp TYLKO dla zalogowanego właściciela.
    // Walidacja:
    //   - request.auth != null — musi być zalogowany (nie guest)
    //   - request.auth.uid == userId — tylko swoje dane, nie cudze
    match /users/{userId}/data/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // === Ścieżki do jawnego zablokowania ====================================
    // Każda inna ścieżka — zero dostępu, nawet dla zalogowanych.
    // To zabezpiecza przed "accidental leaks" gdyby ktoś w kodzie frontend
    // zrobił getDoc('public/secret') — reguły mówią NIE.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
