rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
// BABYLOG / CALM PARENT — FIRESTORE RULES
//
// Zasady:
//   1. Każdy user ma dostęp TYLKO do /users/{userId}/**
//   2. userId MUSI odpowiadać request.auth.uid — nie można czytać cudzych danych
//   3. Niezalogowani (brak auth) — zero dostępu
//   4. Wszystko poza /users/ — zablokowane
//   5. Size limit na dokument — 1MB (ochrona przed abusem limitu Firestore)
//   6. Struktura: tylko pole `value` dozwolone (ochrona przed złośliwymi polami)
//
// Audyt 2026-04-24:
//   - User A nie widzi /users/UID_B (permission denied) ✓
//   - Guest (brak uid) — zero dostępu ✓
//   - Brak ścieżek typu /public/* ✓
//   - Size limit 1MB aktywny ✓
// ══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // === Dane użytkownika ===================================================
    match /users/{userId}/data/{document=**} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 1024 * 1024
                   && request.resource.data.keys().hasOnly(['value', '_metadata']);
    }

    // === Wszystko inne — zablokowane ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
